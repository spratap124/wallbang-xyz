NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/KY2dRw8Yh4

# Optional: force a specific Retake #1 host (otherwise local/dev uses staging
# 129.159.232.212 and production builds use 200.97.169.27).
# NEXT_PUBLIC_RETAKE_HOST=129.159.232.212

# --- Live server status (server-only, never prefix with NEXT_PUBLIC_) ---
# MongoDB Atlas connection string for the serverStatus snapshot cache.
# Use a least-privilege user scoped to the wallbang DB. If unset, the
# /api/servers route falls back to querying servers directly over A2S (no cache).
MONGODB_URI=
MONGODB_DB=wallbang
SERVER_STATUS_TTL_SECONDS=15
SERVER_STATUS_DOC_TTL_SECONDS=120
