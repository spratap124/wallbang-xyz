# Local development — copy to `.env.local` (Next.js loads this automatically):
#   cp .env.example .env.local
#
# Use a SEPARATE Atlas database from production (never point local at prod data).

NEXT_PUBLIC_SITE_URL=http://localhost:3000
# When using `npm run dev:ngrok`, set this to your reserved ngrok URL instead:
# NEXT_PUBLIC_SITE_URL=https://python-tropical-outspoken.ngrok-free.dev
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/KY2dRw8Yh4

# Optional per-server host overrides (id uppercased, `-` → `_`).
# Unset → retake-1 uses staging IP in dev / prod IP in production builds.
# NEXT_PUBLIC_SERVER_HOST_RETAKE_1=129.159.232.212
# Legacy alias for retake-1 only (prefer NEXT_PUBLIC_SERVER_HOST_*):
# NEXT_PUBLIC_RETAKE_HOST=129.159.232.212

# --- Steam login ---
# Create a key at https://steamcommunity.com/dev/apikey (domain: localhost for local).
# AUTH_SECRET: openssl rand -base64 32
# Leave blank to hide the Sign in with Steam button.
STEAM_API_KEY=
AUTH_SECRET=

# --- MongoDB Atlas (development) ---
# Same cluster as prod is fine; use a different database name.
# Leave MONGODB_URI empty to skip Mongo and A2S-query without a cache.
#
# Atlas → Database Access: create user (e.g. wallbang_dev)
# Atlas → Network Access: allow your home IP (or 0.0.0.0/0 for quick local test)
# Atlas → Connect → Drivers → copy the SRV string, then set MONGODB_DB=wallbang_dev
#
# MONGODB_URI=mongodb+srv://wallbang_dev:YOUR_DEV_PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=wallbang_dev
SERVER_STATUS_TTL_SECONDS=15
SERVER_STATUS_DOC_TTL_SECONDS=120

# --- Permissions / admin ---
# Comma-separated SteamID64 values that receive OWNER on login (source: SYSTEM).
OWNER_STEAM_IDS=
# Shared secret for CS2 plugin → GET /api/v1/player/:steamId,
# POST /api/v1/presence, and POST /api/v1/catalog/cosmetics (header: X-API-Key).
PLUGIN_API_KEY=

# How long a player presence heartbeat stays "online" without refresh (seconds).
PLAYER_PRESENCE_TTL_SECONDS=90

# How long player_sessions docs are kept (Mongo TTL on joinedAt). Default 30.
PLAYER_SESSION_RETENTION_DAYS=30

# --- Launch VIP offer (Next.js) ---
# First N Steam logins receive VIP automatically. Announcements post to #launch-giveaway.
# GIVEAWAY_MAX_WINNERS=100
# GIVEAWAY_VIP_MONTHS=3
# Webhook: #launch-giveaway → Channel Settings → Integrations → Webhooks
# DISCORD_GIVEAWAY_WEBHOOK_URL=

# Optional Redis (Compose --profile redis / discord only; not used by the Next.js app yet).
# REDIS_PASSWORD=...
# REDIS_URL=redis://:PASSWORD@127.0.0.1:6379

# --- Optional Discord bot (--profile discord) ---
# Create an app at https://discord.com/developers/applications
# Enable intents: Server Members
# Invite bot with permissions: View Channels, Send Messages (for welcome DMs)
# DISCORD_BOT_TOKEN=
# DISCORD_GUILD_ID=
