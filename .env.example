# Local development — copy to `.env.local` (Next.js loads this automatically):
#   cp .env.example .env.local
#
# Use a SEPARATE Atlas database from production (never point local at prod data).

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/KY2dRw8Yh4

# Optional: force Retake #1 host (otherwise local/dev → staging IP).
# NEXT_PUBLIC_RETAKE_HOST=129.159.232.212

# --- MongoDB Atlas (development) ---
# Same cluster as prod is fine; use a different database name.
# Leave MONGODB_URI empty to skip Mongo and A2S-query without a cache.
#
# Atlas → Database Access: create user (e.g. wallbang_dev)
# Atlas → Network Access: allow your home IP (or 0.0.0.0/0 for quick local test)
# Atlas → Connect → Drivers → copy the SRV string, then set MONGODB_DB=wallbang_dev
#
# MONGODB_URI=mongodb+srv://wallbang_dev:YOUR_DEV_PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=wallbang_dev
SERVER_STATUS_TTL_SECONDS=15
SERVER_STATUS_DOC_TTL_SECONDS=120

# Optional Redis (Compose --profile redis / discord only; not used by the Next.js app yet).
# REDIS_PASSWORD=...
# REDIS_URL=redis://:PASSWORD@127.0.0.1:6379
