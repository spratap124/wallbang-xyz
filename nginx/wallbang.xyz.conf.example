# Nginx reverse proxy for WallBang on the Oracle Always Free app VM.
# Docker Compose binds the Next.js app to 127.0.0.1:3000; nginx terminates TLS.
#
# Install:
#   sudo cp nginx/wallbang.xyz.conf.example /etc/nginx/sites-available/wallbang.xyz
#   sudo ln -sf /etc/nginx/sites-available/wallbang.xyz /etc/nginx/sites-enabled/
#   sudo mkdir -p /var/www/certbot
#   sudo nginx -t && sudo systemctl reload nginx
#   # after DNS A records point here:
#   sudo certbot --nginx -d wallbang.xyz -d www.wallbang.xyz
#
# Certbot will uncomment/fill the ssl_certificate lines automatically when using --nginx.

server {
    listen 80;
    listen [::]:80;
    server_name wallbang.xyz www.wallbang.xyz;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://wallbang.xyz$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name wallbang.xyz www.wallbang.xyz;

    # ssl_certificate     /etc/letsencrypt/live/wallbang.xyz/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/wallbang.xyz/privkey.pem;

    # Cosmetics catalog ingest POSTs can be ~1–2 MB.
    client_max_body_size 5m;

    location /_next/static/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
