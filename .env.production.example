# Production env for Hostinger KVM2 Docker stack.
# Copy to `.env` on the VPS (Compose reads `.env` next to docker-compose.prod.yml):
#   cp .env.production.example .env

NODE_ENV=production

NEXT_PUBLIC_SITE_URL=https://wallbang.xyz
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/KY2dRw8Yh4

# Optional override for Retake #1 (defaults to prod IP in production builds).
# NEXT_PUBLIC_RETAKE_HOST=

# --- MongoDB (Compose service `db` — required) ---
# No default password: Compose will refuse to start if this is unset.
MONGO_PASSWORD=CHANGE_ME_MONGO
# App connection string (password must match MONGO_PASSWORD).
# To use MongoDB Atlas instead, set:
# MONGODB_URI=mongodb+srv://wallbang_app:...@cluster0.xxxxx.mongodb.net/wallbang
MONGODB_URI=mongodb://wallbang:CHANGE_ME_MONGO@db:27017/wallbang?authSource=admin
MONGODB_DB=wallbang
SERVER_STATUS_TTL_SECONDS=15
SERVER_STATUS_DOC_TTL_SECONDS=120

# --- Redis (optional — only with --profile redis or --profile discord) ---
# REDIS_PASSWORD=CHANGE_ME_REDIS
# REDIS_URL=redis://:CHANGE_ME_REDIS@redis:6379

# --- Optional Discord bot (--profile discord) ---
# DISCORD_BOT_TOKEN=
