# Production env for Hostinger KVM2 Docker stack.
# Copy to `.env` on the VPS (never commit real secrets):
#   cp .env.production.example .env
#
# Use a SEPARATE Atlas database from development (MONGODB_DB=wallbang).

NODE_ENV=production

NEXT_PUBLIC_SITE_URL=https://wallbang.xyz
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/KY2dRw8Yh4

# Optional override for Retake #1 (defaults to prod IP in production builds).
# NEXT_PUBLIC_RETAKE_HOST=

# --- Steam login ---
# https://steamcommunity.com/dev/apikey — Domain: wallbang.xyz
# AUTH_SECRET: openssl rand -base64 32
STEAM_API_KEY=
AUTH_SECRET=

# --- MongoDB ---
# Option A — Atlas (recommended for prod)
# Atlas → Database Access: user wallbang_app (readWrite on wallbang)
# Atlas → Network Access: allow the VPS public IP
# Atlas → Connect → Drivers → paste SRV URI below
#
# MONGODB_URI=mongodb+srv://wallbang_app:YOUR_PROD_PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=wallbang
#
# Option B — in-stack Compose Mongo (default below)
# Requires MONGO_PASSWORD; password in MONGODB_URI must match.
MONGO_PASSWORD=CHANGE_ME_MONGO
MONGODB_URI=mongodb://wallbang:CHANGE_ME_MONGO@db:27017/wallbang?authSource=admin
MONGODB_DB=wallbang

SERVER_STATUS_TTL_SECONDS=15
SERVER_STATUS_DOC_TTL_SECONDS=120

# --- Redis (optional — only with --profile redis or --profile discord) ---
# REDIS_PASSWORD=CHANGE_ME_REDIS
# REDIS_URL=redis://:CHANGE_ME_REDIS@redis:6379

# --- Optional Discord bot (--profile discord) ---
# DISCORD_BOT_TOKEN=
