# Copy to .env.production on the Oracle app VM and fill in secrets.
#   cp .env.production.example .env.production
#
# Runtime env for the Docker container (env_file in docker-compose.yml).
# NEXT_PUBLIC_* below are also used as Compose build args when you export
# them or pass --env-file .env.production to `docker compose`.

NEXT_PUBLIC_SITE_URL=https://wallbang.xyz
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/KY2dRw8Yh4

# Optional override for the Retake #1 host (defaults to prod IP when
# NODE_ENV=production). Leave empty in normal production deploys.
# NEXT_PUBLIC_RETAKE_HOST=200.97.169.27

# --- Live server status (server-only, never expose to the browser) ---
# MongoDB Atlas connection string. Least-privilege user scoped to wallbang DB.
MONGODB_URI=mongodb+srv://wallbang_app:CHANGE_ME@cluster0.xxxxx.mongodb.net/wallbang
MONGODB_DB=wallbang
SERVER_STATUS_TTL_SECONDS=15
SERVER_STATUS_DOC_TTL_SECONDS=120
